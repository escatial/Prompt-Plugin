{
  "manifest_version": 3,
  "name": "Prompt Sidebar v0.1.7",
  "version": "0.1.7",
  "description": "A prompt sidebar for Chrome",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "content_scripts": [
    {
      "js": [
        "assets/index.ts-Cf39quiq.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "action": {},
  "options_page": "src/options/index.html",
  "icons": {
    "16": "src/assets/icon.svg",
    "48": "src/assets/icon.svg",
    "128": "src/assets/icon.svg"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Q"
      }
    },
    "toggle-sidebar": {
      "suggested_key": {
        "default": "Alt+Q"
      },
      "description": "Toggle prompt sidebar"
    }
  },
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/index.ts-Cf39quiq.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
