{
  "manifest_version": 3,
  "name": "Prompt Sidebar v0.1.7",
  "version": "0.1.7",
  "description": "A prompt sidebar for Chrome",
  "permissions": ["sidePanel", "storage", "activeTab", "scripting"],
  "background": {
    "service_worker": "src/background/service-worker.ts"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content-script/index.ts"],
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "action": {},
  "options_page": "src/options/index.html",
  "icons": {
    "16": "src/assets/icon.svg",
    "48": "src/assets/icon.svg",
    "128": "src/assets/icon.svg"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Q"
      }
    },
    "toggle-sidebar": {
      "suggested_key": {
        "default": "Alt+Q"
      },
      "description": "Toggle prompt sidebar"
    }
  }
}
